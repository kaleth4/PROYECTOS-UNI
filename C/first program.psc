Algoritmo area
	Definir b, h Como Entero;
	Definir a Como Entero;
	// aqui se pide al usuario los valores a, b
	Escribir 'favor digitar el valor de la base';
	Leer b;
	Escribir 'favor digitar el valor de la Altura';
	Leer h;
	// aqui se realiza el Proceso de la entrada
	a <- (b*h)/2;
	Escribir 'el valor del triangulo es: ', a;
FinAlgoritmo
