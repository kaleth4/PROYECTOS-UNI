Algoritmo Mayor
	//Este programa permite comparar 2 numeros y decir cual es mayor
	//se define variables
	Definir b,h,m  Como Entero;
	Escribir "Digite el numero 1";
	leer b;
	Escribir "Digite el numero 2";
	leer h;
	//Se coloca el condicional
	si b>h Entonces
		Escribir "El numero mayor es: ",b;
	SiNo
		Escribir "El numero mayor es: ",h;
	FinSi
	
	
FinAlgoritmo
