Algoritmo  Convertir temperatura de °C a °F
	//Definimos las variables celsius y fahrenheit
    Definir celsius, fahrenheit Como Real;
    Escribir "Introduce la temperatura en grados Celsius:" ;
    Leer celsius;
	
	// Realizamos la operacion matematica para convertir en fahrenheit
    fahrenheit <- (celsius * 9/5) + 32;
    Escribir "La temperatura en Fahrenheit es: ", fahrenheit;
FinAlgoritmo

